<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'VerdeStats' %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'verde-green': '#00ff77',
            'verde-green-light': '#33ff99',
            'verde-green-dark': '#007a39',
            'void': '#050505',
            'panel': '#0c0c0c',
            'panel-border': '#2a2a2a'
          },
          boxShadow: {
            'green-glow': '0 0 16px rgba(0, 255, 119, 0.55)',
            'green-glow-lg': '0 0 32px rgba(0, 255, 119, 0.65)'
          },
          fontFamily: {
            mono: ['"JetBrains Mono"', 'monospace']
          }
        }
      }
    }
  </script>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Inter', sans-serif;
      background-color: #050505;
      color: #f0f0f0;
      background-image:
        radial-gradient(circle at 20% 0%, rgba(0, 255, 119, 0.08) 0%, transparent 35%),
        radial-gradient(circle at 80% 100%, rgba(0, 255, 119, 0.05) 0%, transparent 30%),
        linear-gradient(rgba(0, 255, 119, 0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0, 255, 119, 0.04) 1px, transparent 1px);
      background-size: 100% 100%, 100% 100%, 40px 40px, 40px 40px;
    }
    .font-mono { font-family: 'JetBrains Mono', monospace; }
    .verde-line {
      background: linear-gradient(90deg, transparent, rgba(0, 255, 119, 0.5), transparent);
      height: 1px;
    }
    .panel {
      background: rgba(12, 12, 12, 0.92);
      border: 1px solid #2a2a2a;
      border-radius: 0.75rem;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
      backdrop-filter: blur(8px);
    }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.6rem 1.25rem;
      background: linear-gradient(135deg, #00ff77 0%, #00cc5f 100%);
      color: #000000;
      font-weight: 800;
      font-size: 0.875rem;
      border: 1px solid #33ff99;
      border-radius: 0.5rem;
      cursor: pointer;
      transition: all 0.2s ease;
      box-shadow: 0 0 12px rgba(0, 255, 119, 0.35);
    }
    .btn-primary:hover {
      background: linear-gradient(135deg, #33ff99 0%, #00ff77 100%);
      box-shadow: 0 0 20px rgba(0, 255, 119, 0.6);
      transform: translateY(-1px);
    }
    .input-field {
      width: 100%;
      padding: 0.65rem 0.9rem;
      background: #141414;
      border: 1px solid #3a3a3a;
      border-radius: 0.5rem;
      color: #ffffff;
      font-size: 0.9rem;
      transition: all 0.2s ease;
      outline: none;
    }
    .input-field::placeholder { color: #777; }
    .input-field:hover { border-color: #555; }
    .input-field:focus {
      border-color: #00ff77;
      box-shadow: 0 0 0 3px rgba(0, 255, 119, 0.15), 0 0 16px rgba(0, 255, 119, 0.25);
      background: #1a1a1a;
    }
    .nav-link {
      padding: 0.5rem 1rem;
      font-size: 0.875rem;
      font-weight: 600;
      color: #a0a0a0;
      border-radius: 0.5rem;
      transition: all 0.2s ease;
      text-decoration: none;
    }
    .nav-link:hover {
      color: #ffffff;
      background: rgba(255, 255, 255, 0.05);
    }
    .nav-link.active {
      color: #00ff77;
      background: rgba(0, 255, 119, 0.1);
      border: 1px solid rgba(0, 255, 119, 0.35);
      box-shadow: 0 0 12px rgba(0, 255, 119, 0.15);
    }
    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-track { background: #0a0a0a; }
    ::-webkit-scrollbar-thumb { background: #00331a; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #00ff77; }
    .glass-header {
      background: rgba(5, 5, 5, 0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid #1f1f1f;
    }
    label.form-label {
      display: block;
      font-size: 0.7rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #33ff99;
      margin-bottom: 0.35rem;
    }
    .hint { color: #888; font-size: 0.75rem; margin-top: 0.25rem; }
    .hint a { color: #33ff99; text-decoration: none; }
    .hint a:hover { text-decoration: underline; }
    .drop-zone {
      border: 2px dashed #3a3a3a;
      background: rgba(20, 20, 20, 0.6);
      transition: all 0.2s ease;
    }
    .drop-zone.dragover {
      border-color: #00ff77;
      background: rgba(0, 255, 119, 0.08);
      box-shadow: 0 0 24px rgba(0, 255, 119, 0.15);
    }
    .bar-bg { background: #1a1a1a; border-radius: 9999px; overflow: hidden; }
    .bar-fill { background: linear-gradient(90deg, #00ff77, #00cc5f); height: 100%; border-radius: 9999px; }
  </style>
</head>
<body class="min-h-screen flex flex-col">
